//não esquecer de executar o npx prisma generate
//depois: npx prisma migrate dev --name add_campo_ativo_cliente

generator client {
  provider = "prisma-client-js"
  //output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DB_CONNECTION")
}

model Cliente {
  id       Int     @id @default(autoincrement())
  nome     String
  telefone String?
  endereco String?
  ativo    Boolean @default(true)

  @@map("clientes")
}
